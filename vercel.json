{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/playground/static/index.html"
    },
    {
      "source": "/playground",
      "destination": "/playground/static/playground.html"
    },
    {
      "source": "/static/:path*",
      "destination": "/playground/static/:path*"
    },
    {
      "source": "/svg/:path*",
      "destination": "/playground/svg/:path*"
    }
  ],
  "headers": [
    {
      "source": "/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/svg/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
