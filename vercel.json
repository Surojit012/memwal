{
  "version": 2,
  "functions": {
    "api/index.py": {
      "includeFiles": [
        "playground/static/**",
        "playground/svg/**"
      ]
    }
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
